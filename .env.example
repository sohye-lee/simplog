# Copy this file to .env.local and fill in the values from your
# Supabase project (Dashboard → Settings → API).
# The anon key is safe to ship in the client; NEVER put the
# service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Google Analytics 4 measurement ID (optional). Leave blank to disable
# analytics entirely. Analytics is also off in dev and when the browser
# sends Do Not Track. Get this from GA4 → Admin → Data streams → Web.
VITE_GA_ID=G-XXXXXXXXXX
